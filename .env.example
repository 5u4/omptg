# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Comma-separated allow list. An update passes auth if EITHER the sender's
# Telegram user id OR the chat id appears here. So:
#  - put your own user id once and you can DM the bot AND use it in any
#    group you're in (without enumerating each group id);
#  - put a group id explicitly if you want *anyone* in that group to be
#    allowed (negative numbers are group ids).
# Find your user id by /whoami after you start the bot once (or message
# @userinfobot).
TELEGRAM_ALLOWED_CHATS=

# Default cwd for chats without an explicit binding in ~/.omp-tg/chats.json.
# OPTIONAL — if unset, falls back to ~/.omp-tg/ (auto-created on first boot).
# Use /bind <path> from telegram to pin a chat (or group) to a different cwd.
OMP_DEFAULT_CWD=
