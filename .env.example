# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Comma-separated allow list. An update passes auth if EITHER the sender's
# Telegram user id OR the chat id appears here. So:
#  - put your own user id once and you can DM the bot AND use it in any
#    group you're in (without enumerating each group id);
#  - put a group id explicitly if you want *anyone* in that group to be
#    allowed (negative numbers are group ids).
# Find your user id by /whoami after you start the bot once (or message
# @userinfobot).
TELEGRAM_ALLOWED_CHATS=

# Default cwd for chats without an explicit binding in ~/.omptg/chats.json.
# OPTIONAL — if unset, falls back to ~/.omptg/ (auto-created on first boot).
# Use /bind <path> from telegram to pin a chat (or group) to a different cwd.
OMP_DEFAULT_CWD=

# Voice transcription via local openai-whisper. Both optional.
#   OMPTG_STT_MODEL: tiny | base | small | medium | large
#     (avoid the *.en variants unless you only ever speak English —
#      they butcher other languages.)
#   OMPTG_STT_LANG:  ISO code (en, zh, ja, fr, …) or "auto"
OMPTG_STT_MODEL=base
OMPTG_STT_LANG=en

# Structured log rotation (logs/<date>.log). Both optional.
#   OMPTG_LOG_COMPRESS_AFTER_DAYS: files older than this get gzipped in place.
#   OMPTG_LOG_RETAIN_DAYS:         files older than this get deleted (covers .gz too).
# Active day's file is always skipped. Rotation runs once per boot.
OMPTG_LOG_COMPRESS_AFTER_DAYS=7
OMPTG_LOG_RETAIN_DAYS=30

# === Discord bridge (optional, separate process: `bun run start:discord`) ===
#
# Discord runs side-by-side with Telegram, not instead of it. ChatStore
# keys are prefixed (tg: / dc:) so the two processes can share
# ~/.omptg/chats.json without colliding. Skip the block entirely if you
# don't use Discord — `bun start` (Telegram) only reads the TELEGRAM_*
# vars above.
#
# Bot token from the Discord developer portal
# (https://discord.com/developers/applications → your app → Bot → Reset Token).
# Enable these privileged intents on the same page: MESSAGE CONTENT INTENT.
# Non-privileged intents the bot requests at gateway login: Guilds,
# GuildMessages, GuildMessageReactions.
DISCORD_BOT_TOKEN=

# CSV allowlist of guild (server) snowflake ids. Empty = allow every
# guild the bot was invited to. Recommended for shared bots.
DISCORD_ALLOWED_GUILDS=

# CSV allowlist of channel snowflake ids the bot will accept top-level
# messages in (and, transitively, threads under those channels). Empty
# = allow every channel inside the guild allowlist.
DISCORD_ALLOWED_CHANNELS=

# CSV of guild ids to register slash commands into instantly. Global
# registration propagates up to 1h; per-guild is immediate, so list
# your dev/test guild here during setup. Empty = global only.
DISCORD_DEV_GUILDS=

# Test-only escape hatch: CSV of bot snowflakes whose messages bypass
# the `msg.author.bot` drop. Used exclusively by `scripts/discord-smoke.ts`
# so a second bot can drive the message handler end-to-end (user-token
# automation would violate Discord TOS). LEAVE EMPTY IN PRODUCTION —
# any bot you list here can post messages your bot will treat as user
# input and run agent turns on.
DISCORD_TEST_BOT_AUTHORS=
