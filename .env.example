# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Comma-separated allow list. An update passes auth if EITHER the sender's
# Telegram user id OR the chat id appears here. So:
#  - put your own user id once and you can DM the bot AND use it in any
#    group you're in (without enumerating each group id);
#  - put a group id explicitly if you want *anyone* in that group to be
#    allowed (negative numbers are group ids).
# Find your user id by /whoami after you start the bot once (or message
# @userinfobot).
TELEGRAM_ALLOWED_CHATS=

# Default cwd for chats without an explicit binding in ~/.omptg/chats.json.
# OPTIONAL — if unset, falls back to ~/.omptg/ (auto-created on first boot).
# Use /bind <path> from telegram to pin a chat (or group) to a different cwd.
OMP_DEFAULT_CWD=

# Voice transcription via local openai-whisper. Both optional.
#   OMPTG_STT_MODEL: tiny | base | small | medium | large
#     (avoid the *.en variants unless you only ever speak English —
#      they butcher other languages.)
#   OMPTG_STT_LANG:  ISO code (en, zh, ja, fr, …) or "auto"
OMPTG_STT_MODEL=base
OMPTG_STT_LANG=en

# Structured log rotation (logs/<date>.log). Both optional.
#   OMPTG_LOG_COMPRESS_AFTER_DAYS: files older than this get gzipped in place.
#   OMPTG_LOG_RETAIN_DAYS:         files older than this get deleted (covers .gz too).
# Active day's file is always skipped. Rotation runs once per boot.
OMPTG_LOG_COMPRESS_AFTER_DAYS=7
OMPTG_LOG_RETAIN_DAYS=30
