{
  "name": "omptg",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "bun run src/main.ts",
    "start:web": "bun run scripts/build-web.ts && bun run src/web-main.ts",
    "build:web": "bun run scripts/build-web.ts",
    "watch:web": "bun run scripts/build-web.ts --watch",
    "smoke": "bun run scripts/smoke.ts",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.web.json",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:restart": "pm2 restart omptg --update-env",
    "pm2:stop": "pm2 stop omptg",
    "pm2:logs": "pm2 logs omptg",
    "pm2:status": "pm2 status omptg",
    "test": "bun test test/"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/dompurify": "^3.2.0",
    "esbuild": "^0.28.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@grammyjs/auto-retry": "^2.0.2",
    "@oh-my-pi/pi-coding-agent": "^15.4.3",
    "@preact/signals": "^2.9.1",
    "dompurify": "^3.4.7",
    "grammy": "^1.43.0",
    "htm": "^3.1.1",
    "marked": "^18.0.4",
    "preact": "^10.29.2",
    "reconnecting-websocket": "^4.4.0",
    "telegramify-markdown": "^1.3.3"
  }
}
